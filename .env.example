# Automata (Royalty) — Required Secrets
# Set these in Supabase Dashboard > Edge Functions > Secrets
# https://supabase.com/dashboard/project/vhpmmfhfwnpmavytoomd/settings/functions

# === REQUIRED ===

# Claude AI (powers Intelligence feed, article generation, support agent)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (payments, subscriptions, webhooks)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email sending + delivery tracking)
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...

# === OPTIONAL ===

# Twilio (SMS sending + delivery tracking)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Web search (for AI research tool)
SERPER_API_KEY=...

# CORS origin (defaults to https://royaltyapp.ai)
ALLOWED_ORIGIN=https://royaltyapp.ai
