{
  "name": "royalty",
  "version": "1.0.0",
  "description": "Royalty - AI-Powered Loyalty Programs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:alpha": "ALPHA_TEST_ENABLED=true playwright test e2e/flows/alpha-*.spec.js",
    "test:alpha:ui": "ALPHA_TEST_ENABLED=true playwright test e2e/flows/alpha-*.spec.js --ui",
    "alpha:check": "bash scripts/alpha-readiness.sh",
    "alpha:start": "npm run alpha:check && npm run dev",
    "check-i18n": "node scripts/check-i18n.js",
    "reset-welcome": "bash scripts/reset-welcome.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@vitest/coverage-v8": "^1.2.0",
    "jsdom": "^23.0.0",
    "stripe": "^20.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "automation",
    "crm",
    "supabase"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "simplex-noise": "^4.0.3",
    "three": "^0.184.0"
  }
}
