    "howItWorks": {
        "tag": "So Funktioniert's",
        "title": "Von Daten Zu Beziehungen in 4 Schritten",
        "subtitle": "Starten Sie in Minuten, nicht Monaten",
        "step1": {
            "title": "Laden Sie Ihre Kunden hoch",
            "desc": "Importieren Sie Ihre bestehende Kundenliste per CSV oder fügen Sie sie manuell hinzu. Fügen Sie beliebige Daten hinzu — Geburtstage, Standorte, Präferenzen."
        },
        "step2": {
            "title": "Erzählen Sie uns von Ihrem Unternehmen",
            "desc": "Teilen Sie Ihren Unternehmenstyp, Ihre Ziele und was Erfolg für Sie bedeutet. Dieser Kontext hilft unserer KI, klügere Vorschläge zu machen."
        },
        "step3": {
            "title": "Überprüfen Sie KI-Vorschläge",
            "desc": "Unsere KI analysiert Ihre Daten und schlägt 5-10 maßgeschneiderte Automatisierungen vor. Überprüfen Sie jede, bearbeiten Sie bei Bedarf und genehmigen Sie mit einem Klick."
        },
        "step4": {
            "title": "Beobachten Sie das Wachstum der Beziehungen",
            "desc": "Automatisierungen laufen nach Ihrem Zeitplan. Kunden erhalten personalisierte Nachrichten. Sie konzentrieren sich auf das Wesentliche — Ihr Geschäft."
        }
